# ============================================================
# CONFIGURACIÓN DEL CRM - cesar cuapan
# Copia este archivo a .env y llena los valores
# ============================================================

# BASE DE DATOS (OBLIGATORIA)
# Para desarrollo local (SQLite, no necesitas nada extra):
# DATABASE_URL="file:./dev.db"
#
# Para producción en Vercel (PostgreSQL gratis sin tarjeta):
# 1. Ve a https://neon.tech y crea cuenta gratis
# 2. Crea un nuevo proyecto en la región más cercana a ti
# 3. En "Connection Details" copia la URL de conexión (empieza con postgresql://)
# 4. Pégala aquí:
DATABASE_URL=""

# SECRETO DE SESIONES (OBLIGATORIO)
# Genera uno seguro con este comando en tu terminal:
#   openssl rand -base64 32
# O usa cualquier texto largo y aleatorio:
AUTH_SECRET=""

# URL de tu app (obligatorio en producción)
# En Vercel se configura automático. En local deja así:
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# ASISTENTE DE IA - ANTHROPIC (OPCIONAL)
# Sin esto el CRM funciona igual, solo usa plantillas locales
# 1. Ve a https://console.anthropic.com
# 2. En el menú izquierdo: "API Keys" → "Create Key"
# 3. Copia la llave (empieza con sk-ant-...)
# ============================================================
ANTHROPIC_API_KEY=""

# ============================================================
# ALMACENAMIENTO DE ARCHIVOS (OPCIONAL)
# Sin esto los archivos se guardan en la base de datos (hasta 10MB por archivo)
# Para archivos más grandes, activa una de estas opciones:
#
# Opción 1 - Vercel Blob (gratis en plan Hobby):
# BLOB_READ_WRITE_TOKEN=""
#
# Opción 2 - Supabase Storage (gratis):
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# ============================================================

# ============================================================
# GOOGLE CALENDAR / MEET (OPCIONAL)
# Sin esto las citas se guardan igual, solo sin evento de Google
# 1. Ve a https://console.cloud.google.com
# 2. Crea proyecto → Habilita "Google Calendar API"
# 3. Credenciales → OAuth 2.0 → Copia ID y secreto
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
